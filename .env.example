# =============================================================
#  MediDispense — Environment Variables
#  Copy to .env and fill in your values
# =============================================================

# App
NODE_ENV=production
PORT=4000

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=medidispense
DB_USER=mediadmin
DB_PASSWORD=Str0ngPass!2025
DATABASE_URL=postgresql://mediadmin:Str0ngPass!2025@postgres:5432/medidispense

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=RedisPass!2025

# MQTT Broker
MQTT_HOST=mqtt_broker
MQTT_PORT=1883
MQTT_USERNAME=backend_service
MQTT_PASSWORD=MqttBack!2025

# JWT
JWT_SECRET=superSecretJWT_MediDispense_2025_changeme!
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=refreshSecret_2025_changeme!
REFRESH_TOKEN_EXPIRES_IN=30d

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@medidispense.co.ke
SMTP_PASS=your_gmail_app_password

# SMS — Africa's Talking
AFRICASTALKING_API_KEY=your_at_api_key_here
AFRICASTALKING_USERNAME=medidispense
SMS_SENDER_ID=MediDisp

# File uploads
UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE_MB=5

# Logging
LOG_LEVEL=info

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_SOCKET_URL=http://localhost:4000
VITE_MQTT_WS_URL=ws://localhost:9001
VITE_APP_NAME=MediDispense

# PgAdmin (dev only)
PGADMIN_DEFAULT_EMAIL=admin@medidispense.co.ke
PGADMIN_DEFAULT_PASSWORD=PgAdmin!2025

# LoRa Bridge
SERIAL_PORT=/dev/ttyUSB0
BAUD_RATE=115200
MQTT_TOPIC_PREFIX=devices
