generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  caregiver
  nurse
  patient
}

enum DeviceStatus {
  online
  offline
  maintenance
  unlinked
}

enum DoseEventType {
  DOSE_TAKEN
  DOSE_MISSED
  DISPENSE_FAIL
  HEARTBEAT
  REFILL
}

enum DoseStatus {
  CONFIRMED
  NOT_CONFIRMED
  NA
  FAILED
}

enum AlertType {
  missed_dose
  low_supply
  device_offline
  dispense_fail
  unauthorized_access
  refill_needed
}

enum AlertSeverity {
  info
  warning
  critical
}

enum NotificationChannel {
  sms
  email
  push
  in_app
}

enum NotificationStatus {
  pending
  sent
  failed
  read
}

enum GenderType {
  male
  female
  other
  prefer_not_to_say
}

model User {
  id              String    @id @default(uuid())
  fullName        String    @map("full_name")
  email           String    @unique
  phone           String?   @unique
  passwordHash    String    @map("password_hash")
  role            UserRole  @default(caregiver)
  avatarUrl       String?   @map("avatar_url")
  isActive        Boolean   @default(true) @map("is_active")
  emailVerified   Boolean   @default(false) @map("email_verified")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  patientsCreated       Patient[]              @relation("PatientCreator")
  patientCaregivers     PatientCaregiver[]
  devicesRegistered     Device[]               @relation("DeviceRegistrar")
  devicePatientLinks    DevicePatientLink[]
  prescriptionsCreated  Prescription[]
  alertsResolved        Alert[]                @relation("AlertResolver")
  notifications         Notification[]
  auditLogs             AuditLog[]
  refreshTokens         RefreshToken[]

  @@map("users")
}

model Patient {
  id                String      @id @default(uuid())
  fullName          String      @map("full_name")
  dateOfBirth       DateTime    @map("date_of_birth") @db.Date
  gender            GenderType
  nationalId        String?     @unique @map("national_id")
  phone             String?
  email             String?
  address           String?
  county            String?
  ward              String?
  nextOfKinName     String?     @map("next_of_kin_name")
  nextOfKinPhone    String?     @map("next_of_kin_phone")
  diagnoses         String[]
  allergies         String[]
  notes             String?
  biometricTemplate Bytes?      @map("biometric_template")
  photoUrl          String?     @map("photo_url")
  isActive          Boolean     @default(true) @map("is_active")
  createdById       String?     @map("created_by")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  createdBy             User?                  @relation("PatientCreator", fields: [createdById], references: [id])
  caregivers            PatientCaregiver[]
  deviceLinks           DevicePatientLink[]
  prescriptions         Prescription[]
  doseEvents            DoseEvent[]
  alerts                Alert[]

  @@map("patients")
}

model PatientCaregiver {
  id         String   @id @default(uuid())
  patientId  String   @map("patient_id")
  userId     String   @map("user_id")
  isPrimary  Boolean  @default(false) @map("is_primary")
  assignedAt DateTime @default(now()) @map("assigned_at")

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([patientId, userId])
  @@map("patient_caregivers")
}

model Device {
  id              String        @id @default(uuid())
  deviceCode      String        @unique @map("device_code")
  label           String?
  firmwareVersion String?       @map("firmware_version")
  macAddress      String?       @unique @map("mac_address")
  loraDevEui      String?       @unique @map("lora_dev_eui")
  status          DeviceStatus  @default(unlinked)
  lastSeenAt      DateTime?     @map("last_seen_at")
  batteryPct      Int?          @map("battery_pct")
  pillsRemaining  Int           @default(0) @map("pills_remaining")
  signalDbm       Int?          @map("signal_dbm")
  rtcSynced       Boolean       @default(false) @map("rtc_synced")
  locationLat     Decimal?      @map("location_lat") @db.Decimal(9, 6)
  locationLng     Decimal?      @map("location_lng") @db.Decimal(9, 6)
  notes           String?
  registeredById  String?       @map("registered_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  registeredBy   User?                @relation("DeviceRegistrar", fields: [registeredById], references: [id])
  patientLinks   DevicePatientLink[]
  doseEvents     DoseEvent[]
  alerts         Alert[]

  @@map("devices")
}

model DevicePatientLink {
  id          String    @id @default(uuid())
  deviceId    String    @map("device_id")
  patientId   String    @map("patient_id")
  linkedById  String?   @map("linked_by")
  linkedAt    DateTime  @default(now()) @map("linked_at")
  unlinkedAt  DateTime? @map("unlinked_at")
  isActive    Boolean   @default(true) @map("is_active")

  device    Device  @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  linkedBy  User?   @relation(fields: [linkedById], references: [id])

  @@map("device_patient_links")
}

model Medication {
  id           String   @id @default(uuid())
  name         String
  genericName  String?  @map("generic_name")
  dosageForm   String?  @map("dosage_form")
  strength     String?
  manufacturer String?
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  prescriptions Prescription[]

  @@map("medications")
}

model Prescription {
  id            String    @id @default(uuid())
  patientId     String    @map("patient_id")
  medicationId  String    @map("medication_id")
  prescribedBy  String?   @map("prescribed_by")
  doseQuantity  Int       @default(1) @map("dose_quantity")
  doseTimes     String[]  @map("dose_times")
  startDate     DateTime  @map("start_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  daysOfWeek    Int[]     @map("days_of_week")
  isActive      Boolean   @default(true) @map("is_active")
  notes         String?
  createdById   String?   @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  patient    Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medication Medication   @relation(fields: [medicationId], references: [id])
  createdBy  User?        @relation(fields: [createdById], references: [id])
  doseEvents DoseEvent[]

  @@map("prescriptions")
}

model DoseEvent {
  id                   String         @id @default(uuid())
  deviceId             String?        @map("device_id")
  patientId            String?        @map("patient_id")
  prescriptionId       String?        @map("prescription_id")
  eventType            DoseEventType  @map("event_type")
  status               DoseStatus
  scheduledAt          DateTime?      @map("scheduled_at")
  dispensedAt          DateTime?      @map("dispensed_at")
  confirmedAt          DateTime?      @map("confirmed_at")
  pillsDispensed       Int            @default(1) @map("pills_dispensed")
  pillsRemainingAfter  Int?           @map("pills_remaining_after")
  biometricId          String?        @map("biometric_id")
  loraPacketRaw        String?        @map("lora_packet_raw")
  rssi                 Int?
  snr                  Decimal?       @db.Decimal(5, 2)
  createdAt            DateTime       @default(now()) @map("created_at")

  device       Device?       @relation(fields: [deviceId], references: [id])
  patient      Patient?      @relation(fields: [patientId], references: [id])
  prescription Prescription? @relation(fields: [prescriptionId], references: [id])
  alerts       Alert[]

  @@map("dose_events")
}

model Alert {
  id           String         @id @default(uuid())
  patientId    String?        @map("patient_id")
  deviceId     String?        @map("device_id")
  doseEventId  String?        @map("dose_event_id")
  alertType    AlertType      @map("alert_type")
  severity     AlertSeverity
  title        String
  message      String
  isResolved   Boolean        @default(false) @map("is_resolved")
  resolvedById String?        @map("resolved_by")
  resolvedAt   DateTime?      @map("resolved_at")
  createdAt    DateTime       @default(now()) @map("created_at")

  patient       Patient?       @relation(fields: [patientId], references: [id])
  device        Device?        @relation(fields: [deviceId], references: [id])
  doseEvent     DoseEvent?     @relation(fields: [doseEventId], references: [id])
  resolvedBy    User?          @relation("AlertResolver", fields: [resolvedById], references: [id])
  notifications Notification[]

  @@map("alerts")
}

model Notification {
  id           String              @id @default(uuid())
  alertId      String?             @map("alert_id")
  userId       String?             @map("user_id")
  channel      NotificationChannel
  recipient    String
  subject      String?
  body         String
  status       NotificationStatus  @default(pending)
  sentAt       DateTime?           @map("sent_at")
  errorMessage String?             @map("error_message")
  retryCount   Int                 @default(0) @map("retry_count")
  createdAt    DateTime            @default(now()) @map("created_at")

  alert Alert? @relation(fields: [alertId], references: [id])
  user  User?  @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}
